# ─────────────────────────────────────────────────────────────────
#  StellarPulse — Environment Variables
#  Copy this file to .env.local and fill in real values after
#  deploying your Soroban contract to testnet.
# ─────────────────────────────────────────────────────────────────

# Stellar Network (testnet | mainnet | futurenet)
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Soroban RPC URL for testnet
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Contract ID — fill this in after deploying with deploy.sh
# Example: CABC...XYZ (56 character Stellar contract address)
NEXT_PUBLIC_CONTRACT_ID=YOUR_CONTRACT_ID_HERE

# Polling interval for real-time updates (milliseconds)
NEXT_PUBLIC_POLL_INTERVAL_MS=5000
